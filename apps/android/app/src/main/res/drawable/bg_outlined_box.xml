<?xml version="1.0" encoding="utf-8"?>
<!--
  Plain shape background for the file-list box in ShareActivity.
  MaterialCardView deliberately applies a tonal elevation-overlay tint inside
  floating/dialog windows (Material3 dialog surface behavior, not a bug), which
  fights our flat "Registre libre" cream surface. A plain shape drawable has no
  such logic, so it renders the exact colors we set.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/registre_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/registre_outline" />
    <corners android:radius="4dp" />
</shape>
